---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Cesar's Personal Website"
  description="A personal website in progress, with Sanity Studio powering the current editing workflow."
>
  <main class="flex min-h-screen items-center justify-center px-6 py-16">
    <section class="w-full max-w-2xl space-y-6 text-center">
      <p
        class="text-xs font-semibold tracking-[0.3em] text-neutral-500 uppercase"
      >
        Personal Website
      </p>

      <h1
        class="text-4xl font-semibold tracking-tight text-neutral-950 sm:text-5xl"
      >
        The site is taking shape.
      </h1>

      <p
        class="mx-auto max-w-xl text-base leading-7 text-neutral-600 sm:text-lg"
      >
        This space is being built out as the foundation for my personal website.
        For now, Sanity Studio is the place where the structure, content, and
        publishing workflow are coming together.
      </p>

      <div class="space-y-4 pt-2">
        <a
          href="/studio"
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center justify-center rounded-full bg-neutral-950 px-6 py-3 text-sm font-medium text-white transition hover:bg-neutral-800 focus:ring-2 focus:ring-neutral-950 focus:ring-offset-2 focus:outline-none"
        >
          Open Studio
        </a>

        <p class="text-sm text-neutral-600">
          Or preview the current post route at
          <a
            href="/post/hello-world"
            class="font-medium text-neutral-950 underline decoration-neutral-300 underline-offset-4 transition hover:decoration-neutral-950"
          >
            /post/hello-world
          </a>
          .
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
